{
	"name": "illvenn",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"scripts": {
		"lint": "pnpm -r lint",
		"typecheck": "pnpm -r typecheck",
		"clean": "pnpm -r clean",
		"infra": "docker compose up -d postgres redis rabbitmq minio traefik",
		"infra:down": "docker compose down",
		"infra:logs": "docker compose logs -f",
		"infra:ps": "docker compose ps",
		"db:generate": "pnpm --filter @illvenn/db generate",
		"db:migrate": "pnpm --filter @illvenn/db migrate",
		"db:seed": "pnpm --filter @illvenn/db seed",
		"db:studio": "pnpm --filter @illvenn/db studio",
		"dev:auth": "pnpm --filter @illvenn/auth dev",
		"dev:voice": "pnpm --filter @illvenn/voice dev",
		"dev:worker": "pnpm --filter @illvenn/worker dev",
		"dev:web": "pnpm --filter @illvenn/web dev"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.30.3",
	"devDependencies": {
		"@types/node": "^25.3.3",
		"prettier": "^3.8.1",
		"typescript": "^5.9.3"
	}
}
